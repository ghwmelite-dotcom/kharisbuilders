---
import PublicLayout from '../../layouts/PublicLayout.astro';
import PageHero from '../../components/PageHero.astro';
import EventCard from '../../components/EventCard.astro';
import { env } from '../../lib/runtime';
import { mediaUrl } from '../../lib/media';
import { PLACEHOLDER } from '../../lib/images';
import { SITE } from '../../lib/seo';
import { listUpcomingEvents, type EventRow } from '../../lib/db/events';
import { getAllContent } from '../../lib/db/content';
import { makeImage } from '../../lib/content/content';
import { feature } from '../../config/church';

if (!feature('events')) return Astro.redirect('/');

const cimg = makeImage(await getAllContent(env.DB).catch(() => ({})));

let events: EventRow[] = [];
try {
  events = await listUpcomingEvents(env.DB);
} catch {
  events = [];
}
const imgs = [PLACEHOLDER.card, PLACEHOLDER.card, PLACEHOLDER.card];
---
<PublicLayout title={`Events | ${SITE.name}`} description={`Upcoming gatherings at ${SITE.name}.`} image={cimg('pages.events_hero')}>
  <PageHero image={cimg('pages.events_hero')} height="h-[360px] md:h-[460px]">
    <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-4 block hero-shadow">What's On</span>
    <h1 class="font-display text-display-mobile md:text-display-lg text-white hero-shadow">Upcoming Events</h1>
    <p class="font-body text-body-lg text-white/85 max-w-2xl mx-auto mt-4 hero-shadow">
      Gather, grow, and belong — here's what's coming up.
    </p>
  </PageHero>
  <section class="py-24 px-margin-mobile md:px-margin-desktop max-w-[var(--container-max)] mx-auto">
    {
      events.length === 0 ? (
        <p class="text-center text-stone-gray font-body">No upcoming events right now — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10" data-reveal>
          {events.map((e, i) => (
            <EventCard event={e} image={mediaUrl(e.image_key) ?? imgs[i % imgs.length]} />
          ))}
        </div>
      )
    }
  </section>
</PublicLayout>
