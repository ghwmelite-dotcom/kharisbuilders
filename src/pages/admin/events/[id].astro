---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import EventForm from '../../../components/admin/EventForm.astro';
import { env } from '../../../lib/runtime';
import { getAdminEmail } from '../../../lib/admin-auth';
import { getEventById } from '../../../lib/db/events';

const email = getAdminEmail(Astro.request, env, import.meta.env.DEV);
if (!email) return Astro.redirect('/admin/denied');
const event = await getEventById(env.DB, Number(Astro.params.id)).catch(() => null);
if (!event) return Astro.redirect('/admin/events');
---
<AdminLayout title="Edit Event" email={email} active="events">
  <EventForm event={event} />
  <a href={`/admin/events/${event.id}/registrations`} class="inline-block mt-8 mr-6 text-accent text-sm uppercase tracking-widest">View registrations →</a>
  <a href="/admin/events" class="inline-block mt-8 text-accent text-sm uppercase tracking-widest">← Back</a>
</AdminLayout>
