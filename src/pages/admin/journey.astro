---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from '../../lib/runtime';
import { getAdminEmail } from '../../lib/admin-auth';
import { listJourney } from '../../lib/db/journey';
const email = getAdminEmail(Astro.request, env, import.meta.env.DEV);
if (!email) return Astro.redirect('/admin/denied');
const milestones = await listJourney(env.DB).catch(() => []);
---
<AdminLayout title="Journey" email={email} active="journey">
  <a href="/admin/journey/new" class="inline-block mb-6 bg-primary text-on-primary px-5 py-2 text-sm uppercase tracking-wider">+ New milestone</a>
  <table class="w-full text-sm">
    <thead>
      <tr class="text-left text-on-surface-variant border-b border-champagne">
        <th class="py-2">Year</th><th>Title</th><th>Order</th><th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody>
      {
        milestones.map((m) => (
          <tr class="border-b border-champagne/50">
            <td class="py-3"><a href={`/admin/journey/${m.id}`} class="text-primary hover:text-accent">{m.year}</a></td>
            <td>{m.title}</td>
            <td>{m.sort_order}</td>
            <td class="text-right">
              <form method="POST" action="/api/admin/journey" class="inline" onsubmit="return confirm('Delete this milestone?')">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={String(m.id)} />
                <button class="text-accent-deep text-xs uppercase tracking-wider">Delete</button>
              </form>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
  {milestones.length === 0 && <p class="text-on-surface-variant mt-4">No milestones yet.</p>}
</AdminLayout>
