---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SermonForm from '../../../components/admin/SermonForm.astro';
import { env } from '../../../lib/runtime';
import { getAdminEmail } from '../../../lib/admin-auth';

const email = getAdminEmail(Astro.request, env, import.meta.env.DEV);
if (!email) return Astro.redirect('/admin/denied');
---
<AdminLayout title="New Sermon" email={email} active="sermons">
  <SermonForm />
  <a href="/admin/sermons" class="inline-block mt-8 text-accent text-sm uppercase tracking-widest">← Back</a>
</AdminLayout>
