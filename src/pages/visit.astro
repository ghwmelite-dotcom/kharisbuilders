---
import PublicLayout from '../layouts/PublicLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import Field from '../components/Field.astro';
import { env } from '../lib/runtime';
import { getAllSettings } from '../lib/db/settings';
import { getAllContent } from '../lib/db/content';
import { makeContent, makeImage } from '../lib/content/content';
import { SITE } from '../lib/seo';

let address = '';
let siteKey = '1x00000000000000000000AA';
let serviceTimes: Array<{ name: string; time: string; note?: string }> = [];
let contentMap: Record<string, string> = {};
try {
  const [settings, cm] = await Promise.all([getAllSettings(env.DB), getAllContent(env.DB)]);
  address = settings.address ?? '';
  siteKey = settings.turnstile_site_key ?? siteKey;
  serviceTimes = settings.service_times ? JSON.parse(settings.service_times) : [];
  contentMap = cm;
} catch {
  /* defaults */
}
const c = makeContent(contentMap);
const cimg = makeImage(contentMap);
const submitted = Astro.url.searchParams.get('submitted') === '1';
const serviceOptions = serviceTimes.map((s) => `${s.name} ${s.time}`);
const mapsHref = address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`
  : 'https://www.google.com/maps';
---
<PublicLayout title={`Visit Us | ${SITE.name}`} description={`Plan your visit to ${SITE.name}.`} image="/images/pages/visit.jpg">
  <!-- Hero -->
  <PageHero image={cimg('visit.hero_image')}>
    <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-4 block hero-shadow">{c('visit.hero_kicker')}</span>
    <h1 class="font-display text-display-mobile md:text-display-lg text-white mb-4 hero-shadow">{c('visit.hero_title')}</h1>
    <p class="font-body text-body-lg text-white/85 max-w-2xl mx-auto hero-shadow whitespace-pre-line">{c('visit.hero_subtitle')}</p>
  </PageHero>

  <!-- Service times + Plan Your Visit -->
  <section class="py-24 px-margin-mobile md:px-margin-desktop max-w-[var(--container-max)] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start" data-reveal>
      <div class="lg:col-span-7">
        <h2 class="font-display text-headline-lg text-primary mb-12 flex items-center gap-4">
          <span class="kente-rule w-12"></span>
          Service Times
        </h2>
        <div class="space-y-2">
          {
            serviceTimes.map((s, i) => (
              <div class={`flex justify-between items-center py-6 ${i < serviceTimes.length - 1 ? 'border-b border-heritage-gold/20' : ''}`}>
                <div>
                  <h3 class="font-display text-headline-md text-midnight-blue">{s.name}</h3>
                  {s.note && <p class="font-body text-body-md text-stone-gray">{s.note}</p>}
                </div>
                <span class="font-display text-headline-md text-heritage-gold block">{s.time}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-5 bg-surface-container p-8 md:p-12 elev-2">
        {
          submitted ? (
            <p class="font-display text-headline-md text-primary">Thank you — we'll see you soon!</p>
          ) : (
            <div class="space-y-8">
              <div>
                <span class="font-label-sm uppercase tracking-widest text-heritage-gold block mb-2">{c('visit.plan_eyebrow')}</span>
                <h2 class="font-display text-headline-lg text-primary mb-4">{c('visit.plan_heading')}</h2>
                <p class="font-body text-body-md text-stone-gray mb-8 whitespace-pre-line">{c('visit.plan_body')}</p>
              </div>
              <form method="POST" action="/api/forms/visit" class="space-y-6">
                <Field label="Full Name" name="name" required />
                <Field label="Email Address" name="email" type="email" required />
                <Field label="I'm coming on..." name="visiting_service" options={serviceOptions} />
                <div class="cf-turnstile" data-sitekey={siteKey} />
                <button type="submit" class="w-full bg-midnight-blue text-white font-label-md uppercase tracking-widest py-4 border-b-2 border-transparent hover:border-heritage-gold transition-all">
                  Confirm Attendance
                </button>
              </form>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Find Us -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <div class="h-[420px] md:h-[500px] bg-surface-dim relative overflow-hidden shadow-[0_10px_30px_-10px_rgba(26,43,66,0.1)]">
            <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, #2c1745 1px, transparent 0); background-size: 24px 24px;"></div>
            <div class="absolute inset-0 flex items-center justify-center text-center">
              <div>
                <svg class="w-12 h-12 text-heritage-gold mx-auto mb-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z" /></svg>
                <p class="font-label-md uppercase tracking-widest text-stone-gray">Our sanctuary</p>
              </div>
            </div>
          </div>
        </div>
        <div class="order-1 md:order-2 space-y-8">
          <h2 class="font-display text-headline-lg text-primary">Find Us</h2>
          <div class="space-y-6">
            <div>
              <h4 class="font-label-md uppercase tracking-widest text-midnight-blue mb-1">Our Address</h4>
              <p class="font-body text-body-md text-stone-gray">{address || '12 Cathedral Way, West End, London'}</p>
            </div>
            <div>
              <h4 class="font-label-md uppercase tracking-widest text-midnight-blue mb-1">Parking</h4>
              <p class="font-body text-body-md text-stone-gray whitespace-pre-line">{c('visit.parking_body')}</p>
            </div>
            <div class="pt-4">
              <a href={mapsHref} target="_blank" rel="noopener" class="inline-flex items-center gap-3 font-label-md uppercase tracking-widest text-midnight-blue border-b border-heritage-gold pb-1">
                Get Directions via Google Maps →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-28 px-margin-mobile md:px-margin-desktop max-w-[var(--container-max)] mx-auto">
    <SectionIntro eyebrow={c('visit.expect_eyebrow')} title={c('visit.expect_heading')} class="mb-16" />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
      <div class="md:col-span-2 bg-surface-container-lowest p-10 md:p-12 border-t-2 border-heritage-gold shadow-[0_10px_30px_-10px_rgba(26,43,66,0.08)]">
        <h3 class="font-display text-headline-md text-primary mb-4">{c('visit.expect_q1_title')}</h3>
        <p class="font-body text-body-md text-stone-gray leading-relaxed whitespace-pre-line">{c('visit.expect_q1_body')}</p>
      </div>
      <div class="bg-midnight-blue p-10 md:p-12 text-white">
        <h3 class="font-display text-headline-md mb-4">{c('visit.expect_kids_title')}</h3>
        <p class="font-body text-body-md opacity-80 leading-relaxed whitespace-pre-line">{c('visit.expect_kids_body')}</p>
      </div>
      <div class="bg-surface-container-high p-10 md:p-12">
        <h3 class="font-display text-headline-md text-primary mb-4">{c('visit.expect_service_title')}</h3>
        <p class="font-body text-body-md text-stone-gray leading-relaxed whitespace-pre-line">{c('visit.expect_service_body')}</p>
      </div>
      <div class="md:col-span-2 relative min-h-[300px] overflow-hidden group">
        <img src={cimg('visit.afterward_image')} alt="" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" />
        <div class="absolute inset-0 bg-midnight-blue/60 flex items-end p-10 md:p-12">
          <div class="text-white">
            <h3 class="font-display text-headline-md mb-2">{c('visit.expect_afterward_title')}</h3>
            <p class="font-body text-body-md opacity-90 max-w-md whitespace-pre-line">{c('visit.expect_afterward_body')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</PublicLayout>
