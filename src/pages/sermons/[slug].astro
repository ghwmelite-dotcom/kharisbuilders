---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { env } from '../../lib/runtime';
import { getSermonBySlug } from '../../lib/db/sermons';
import { toEmbedUrl } from '../../lib/video';
import { SITE, videoJsonLd } from '../../lib/seo';
import { feature } from '../../config/church';

if (!feature('sermons')) return Astro.redirect('/');

const { slug } = Astro.params;
const sermon = slug ? await getSermonBySlug(env.DB, slug).catch(() => null) : null;
if (!sermon) return Astro.redirect('/sermons');
const embed = toEmbedUrl(sermon.video_provider, sermon.video_url);
const origin = (Astro.site ?? new URL(SITE.url)).origin;
const sermonNode = videoJsonLd(origin, sermon);
---
<PublicLayout
  title={`${sermon.title} | Sermons`}
  description={sermon.description ?? sermon.title}
  type="video.other"
  image={sermon.thumbnail_key ? `/media/${sermon.thumbnail_key}` : '/images/pages/sermons.jpg'}
  jsonLd={[sermonNode]}
>
  <!-- Dark player section -->
  <section class="bg-primary-container py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="text-center mb-10">
        {sermon.series && <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-4 block">{sermon.series}</span>}
        <h1 class="font-display text-display-mobile md:text-headline-lg text-white mb-4">{sermon.title}</h1>
        <p class="font-body text-body-md text-white/70">
          {sermon.speaker}{sermon.speaker && sermon.sermon_date ? ' · ' : ''}{sermon.sermon_date}
          {sermon.scripture_ref && <span> · {sermon.scripture_ref}</span>}
        </p>
      </div>
      <div class="aspect-video overflow-hidden border border-white/10 shadow-2xl">
        {
          embed ? (
            <iframe
              class="w-full h-full"
              src={embed}
              title={sermon.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          ) : (
            <a href={sermon.video_url} class="w-full h-full flex items-center justify-center bg-midnight-blue text-white underline" target="_blank" rel="noopener">
              Watch this sermon
            </a>
          )
        }
      </div>
    </div>
  </section>
  {
    sermon.description && (
      <section class="py-20 px-margin-mobile md:px-margin-desktop">
        <div class="max-w-3xl mx-auto">
          <p class="font-body text-body-lg text-stone-gray leading-relaxed">{sermon.description}</p>
        </div>
      </section>
    )
  }
  <section class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop pb-12">
    <div id="study-guide" data-slug={sermon.slug} class="hidden">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold">Study Guide</span>
        <span class="kente-rule flex-1"></span>
      </div>
      <div id="sg-body" class="space-y-8"></div>
      <p class="font-body text-body-sm text-stone-gray mt-6">
        Generated by AI from this message — a starting point for reflection, not a substitute for it.
      </p>
    </div>
    <div id="sg-skeleton" class="animate-pulse space-y-4">
      <div class="h-4 bg-surface-container-high rounded w-1/3"></div>
      <div class="h-3 bg-surface-container-high rounded w-full"></div>
      <div class="h-3 bg-surface-container-high rounded w-5/6"></div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop pb-24">
    <a href="/sermons" class="text-heritage-gold font-label-md uppercase tracking-widest border-b border-heritage-gold/40 hover:border-heritage-gold transition-all">
      ← All sermons
    </a>
  </div>

  <script>
    (async () => {
      const root = document.getElementById('study-guide');
      const skel = document.getElementById('sg-skeleton');
      const body = document.getElementById('sg-body');
      if (!root || !body) return;
      const slug = root.getAttribute('data-slug');
      try {
        const res = await fetch(`/api/ai/study-guide?sermon=${encodeURIComponent(slug || '')}`);
        const data = await res.json();
        if (!data.available) {
          skel?.remove();
          return;
        }
        const g = data.guide;
        const esc = (t) => String(t).replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c]);
        const list = (title, items) =>
          items && items.length
            ? `<div><h3 class="font-display text-headline-md text-primary mb-3">${title}</h3><ul class="list-disc pl-5 space-y-2 font-body text-body-md text-stone-gray">${items
                .map((i) => `<li>${esc(i)}</li>`)
                .join('')}</ul></div>`
            : '';
        body.innerHTML =
          (g.summary ? `<p class="font-body text-body-lg text-stone-gray leading-relaxed">${esc(g.summary)}</p>` : '') +
          list('Key points', g.keyPoints) +
          list('Reflection questions', g.reflectionQuestions) +
          list('Related scriptures', g.relatedScriptures);
        skel?.remove();
        root.classList.remove('hidden');
      } catch {
        skel?.remove();
      }
    })();
  </script>
</PublicLayout>
