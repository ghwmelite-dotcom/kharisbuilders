---
import PublicLayout from '../layouts/PublicLayout.astro';
import Adinkra from '../components/Adinkra.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { env } from '../lib/runtime';
import { listPublishedSermons } from '../lib/db/sermons';
import { listUpcomingEvents } from '../lib/db/events';
import { getAllSettings } from '../lib/db/settings';
import { getAllContent } from '../lib/db/content';
import { makeContent, makeImage } from '../lib/content/content';
import { mediaUrl } from '../lib/media';
import { listHomeCards } from '../lib/db/homeCards';
import { PLACEHOLDER } from '../lib/images';
import { SITE } from '../lib/seo';
import { CHURCH, feature } from '../config/church';

let latestSermon: Awaited<ReturnType<typeof listPublishedSermons>>[number] | null = null;
let events: Awaited<ReturnType<typeof listUpcomingEvents>> = [];
let serviceTimes: Array<{ name: string; time: string; note?: string }> = [];
let contentMap: Record<string, string> = {};
let dbCards: Awaited<ReturnType<typeof listHomeCards>> = [];
try {
  const [s, e, settings, cm, cards] = await Promise.all([
    listPublishedSermons(env.DB, 1),
    listUpcomingEvents(env.DB, 3),
    getAllSettings(env.DB),
    getAllContent(env.DB),
    listHomeCards(env.DB),
  ]);
  latestSermon = s[0] ?? null;
  events = e;
  serviceTimes = settings.service_times ? JSON.parse(settings.service_times) : [];
  contentMap = cm;
  dbCards = cards;
} catch {
  /* fall back to static content */
}
const c = makeContent(contentMap);
const cimg = makeImage(contentMap);
const scriptureBg = `linear-gradient(rgba(44,23,69,0.86), rgba(44,23,69,0.92)), url('${cimg('home.scripture_image')}')`;
const eventImages = [PLACEHOLDER.card, PLACEHOLDER.card, PLACEHOLDER.card];
const fmtDate = (s: string) => s?.slice(0, 10) ?? '';
// Intro cards that overlap the hero's bottom edge — the signature church-theme depth device.
// Render from the editable home_cards list, falling back to the original three when empty.
const cardFallbackImg = [PLACEHOLDER.card, PLACEHOLDER.card, PLACEHOLDER.card];
const defaultCards = [
  { eyebrow: 'New Here?', title: 'Plan a Visit', href: '/visit', description: 'Know what to expect and let us welcome you home.', image_key: null },
  { eyebrow: 'Messages', title: 'Watch Sermons', href: '/sermons', description: 'Catch up on recent messages, anytime, anywhere.', image_key: null },
  { eyebrow: 'Generosity', title: 'Give', href: '/giving', description: 'Partner with the mission and the ministries.', image_key: null },
];
const introCards = (dbCards.length ? dbCards : defaultCards).map((cd, i) => ({
  label: cd.eyebrow ?? '',
  title: cd.title,
  href: cd.href,
  desc: cd.description ?? '',
  img: mediaUrl(cd.image_key ?? null) ?? cardFallbackImg[i % cardFallbackImg.length],
}));
---
<PublicLayout title={`${SITE.name} | ${SITE.tagline}`} image={cimg('home.hero_image')}>
  <!-- Cinematic hero -->
  <section class="relative min-h-dvh flex flex-col overflow-hidden bg-primary">
    <img src={cimg('home.hero_image')} alt="" class="kenburns absolute inset-0 w-full h-full object-cover opacity-[0.72]" />
    <!-- theme-toned legibility gradient: darkens top (nav) + bottom (cards), lets the photo shine through the middle -->
    <div class="absolute inset-0" style="background: linear-gradient(180deg, color-mix(in srgb, var(--kb-primary-container) 56%, transparent) 0%, color-mix(in srgb, var(--kb-primary-container) 10%, transparent) 42%, color-mix(in srgb, var(--kb-primary-container) 26%, transparent) 66%, color-mix(in srgb, var(--kb-primary-container) 88%, transparent) 100%);"></div>
    <!-- brand-color glows sit over the darkened scene (screen blend) -->
    <div class="hero-glows absolute inset-0 pointer-events-none">
      <span class="glow glow-orange"></span>
      <span class="glow glow-blue"></span>
      <span class="glow glow-purple"></span>
      <span class="glow glow-red"></span>
    </div>
    <!-- focused scrim directly behind the headline (keeps the type legible without dimming the whole photo) -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(50% 40% at 50% 45%, color-mix(in srgb, var(--kb-primary-container) 50%, transparent), transparent 72%);"></div>

    <!-- content centred in a region that clears the nav (top) and reserves space for the overlapping cards (bottom) -->
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 pt-28 pb-44 md:pb-56">
      <div class="text-center max-w-4xl mx-auto w-full">
      <img src={CHURCH.logo} alt="" class="hero-swirl hero-fade w-20 h-20 md:w-24 md:h-24 mx-auto mb-7" style="--line-delay:0ms" />
      <span class="hero-line inline-flex items-center gap-3 font-label-sm uppercase tracking-[0.45em] text-heritage-gold mb-6" style="--line-delay:140ms; text-shadow:0 1px 10px rgba(0,0,0,0.6);">
        <Adinkra symbol="adinkrahene" class="w-3.5 h-3.5 opacity-80" />
        {c('home.hero_kicker')}
        <Adinkra symbol="adinkrahene" class="w-3.5 h-3.5 opacity-80" />
      </span>
      <h1 class="font-display text-display-mobile md:text-display-lg text-white mb-10" style="text-shadow:0 2px 24px rgba(0,0,0,0.55);">
        <span class="hero-line block" style="--line-delay:240ms">{c('home.hero_line1')}</span>
        <span class="hero-line block text-gold-gradient" style="--line-delay:360ms; filter: drop-shadow(0 2px 14px rgba(0,0,0,0.6));">{c('home.hero_line2')}</span>
      </h1>

      <!-- Live next-gathering countdown -->
      <div class="hero-fade inline-flex flex-wrap justify-center items-center gap-x-5 gap-y-2 glass-card rounded-full px-7 py-3.5 mb-9" style="--line-delay:560ms">
        <span class="font-label-sm uppercase tracking-[0.25em] text-heritage-gold">Next Gathering</span>
        <span class="w-px h-6 bg-white/20 hidden sm:block"></span>
        <span id="hero-countdown" class="font-display text-white text-xl tabular-nums tracking-wide" data-schedule={c('home.gathering_schedule')}>—</span>
        <span class="w-px h-6 bg-white/20 hidden sm:block"></span>
        <span id="hero-next" class="font-body text-body-md text-white/70 hidden sm:block">Sunday · 9:00 AM</span>
      </div>

      <div class="hero-fade flex flex-col sm:flex-row gap-4 justify-center items-center" style="--line-delay:680ms">
        <a href={c('home.cta1_href')} class="bg-heritage-gold text-primary hover:bg-secondary hover:text-white font-label-md uppercase tracking-[0.14em] px-10 py-5 transition-colors duration-300">{c('home.cta1_label')}</a>
        <a href={c('home.cta2_href')} class="btn-fill border border-white/40 text-white font-label-md uppercase tracking-[0.14em] px-10 py-5">{c('home.cta2_label')}</a>
      </div>
      </div>
    </div>
  </section>

  <!-- Overlapping intro cards — depth device that breaks the hero's bottom edge -->
  <section class="relative z-20 -mt-16 md:-mt-24 px-margin-mobile md:px-margin-desktop">
    <div class="max-w-[var(--container-max)] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {
        introCards.map((c, i) => (
          <a
            href={c.href}
            class="card-lift group relative block overflow-hidden bg-surface-container-lowest elev-2 border-t-2 border-heritage-gold"
            data-reveal
            style={`--reveal-delay:${i * 110}ms`}
          >
            <div class="relative aspect-[16/10] overflow-hidden">
              <img src={c.img} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/10 to-transparent" />
            </div>
            <div class="p-7 md:p-8">
              <span class="font-label-sm uppercase tracking-[0.25em] text-heritage-gold">{c.label}</span>
              <h3 class="font-display text-headline-md text-primary mt-2 mb-3 group-hover:text-heritage-gold transition-colors">{c.title}</h3>
              <p class="font-body text-body-md text-stone-gray mb-5">{c.desc}</p>
              <span class="inline-flex items-center gap-2 font-label-sm uppercase tracking-[0.18em] text-primary">
                Explore
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
  <script>
    (function () {
      const out = document.getElementById('hero-countdown');
      const nextEl = document.getElementById('hero-next');
      if (!out) return;
      let sched = [
        [0, 9, 0, 'Sunday · 9:00 AM'],
        [0, 17, 30, 'Sunday · 5:30 PM'],
        [3, 19, 0, 'Wednesday · 7:00 PM'],
      ];
      try {
        const raw = out.getAttribute('data-schedule');
        if (raw) {
          const parsed = JSON.parse(raw);
          if (Array.isArray(parsed) && parsed.length) sched = parsed.map((x) => [x.day, x.hour, x.min || 0, x.label]);
        }
      } catch (e) {
        /* keep the default schedule */
      }
      function nextOccurrence(day, h, m) {
        const now = new Date();
        const d = new Date(now);
        d.setHours(h, m, 0, 0);
        let add = (day - d.getDay() + 7) % 7;
        if (add === 0 && d <= now) add = 7;
        d.setDate(d.getDate() + add);
        return d;
      }
      function tick() {
        const now = new Date();
        let best = null;
        let bestLabel = '';
        for (const [day, h, m, label] of sched) {
          const t = nextOccurrence(day, h, m);
          if (!best || t < best) {
            best = t;
            bestLabel = label;
          }
        }
        let s = Math.max(0, Math.floor((best.getTime() - now.getTime()) / 1000));
        const dd = Math.floor(s / 86400);
        s %= 86400;
        const hh = Math.floor(s / 3600);
        s %= 3600;
        const mm = Math.floor(s / 60);
        const ss = s % 60;
        const pad = (n) => String(n).padStart(2, '0');
        out.textContent = `${dd}d ${pad(hh)}h ${pad(mm)}m ${pad(ss)}s`;
        if (nextEl) nextEl.textContent = bestLabel;
      }
      tick();
      setInterval(tick, 1000);
    })();
  </script>

  <!-- Pastor's welcome — layered offset gold frame -->
  <section class="py-28 md:py-40 bg-surface overflow-hidden">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-gutter md:gap-16 items-center">
      <div class="md:col-span-5 relative" data-reveal>
        <!-- offset gold frame behind the portrait -->
        <div class="absolute inset-0 translate-x-4 translate-y-4 md:translate-x-6 md:translate-y-6 border border-heritage-gold/60 pointer-events-none"></div>
        <div class="relative aspect-[3/4] overflow-hidden elev-3">
          <img src={cimg('home.pastor_image')} alt="Our Lead Pastor" class="kenburns w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent"></div>
        </div>
        <Adinkra symbol="adinkrahene" class="absolute -top-6 -left-6 w-14 h-14 text-heritage-gold/30 hidden md:block" />
      </div>
      <div class="md:col-span-7 mt-16 md:mt-0" data-reveal style="--reveal-delay:120ms">
        <span class="inline-flex items-center gap-3 font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-5">
          <Adinkra symbol="adinkrahene" class="w-3.5 h-3.5 opacity-80" />
          {c('home.pastor_eyebrow')}
        </span>
        <h2 class="font-display text-display-mobile md:text-headline-lg text-primary mb-8 pullquote">{c('home.pastor_heading')}</h2>
        <p class="font-body text-body-lg text-stone-gray mb-6 leading-relaxed whitespace-pre-line">{c('home.pastor_body1')}</p>
        <p class="font-body text-body-lg text-stone-gray mb-10 leading-relaxed whitespace-pre-line">{c('home.pastor_body2')}</p>
        <div class="flex items-center gap-4">
          <span class="kente-rule w-12"></span>
          <span class="font-display text-headline-md text-primary italic">{c('home.pastor_name')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Scripture statement band (dark, subtle desktop parallax) -->
  <section
    class="parallax-fixed relative py-28 md:py-44 bg-primary-container"
    style={`background-image: ${scriptureBg};`}
  >
    <div class="hero-glows absolute inset-0 pointer-events-none opacity-60">
      <span class="glow glow-orange"></span>
      <span class="glow glow-purple"></span>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center" data-reveal>
      <Adinkra symbol="nyame-dua" class="w-10 h-10 text-heritage-gold/80 mx-auto mb-8" title="Nyame Dua — the presence of God" />
      <blockquote class="font-display text-3xl md:text-5xl leading-[1.25] text-white pullquote hero-shadow">
        “{c('home.scripture_verse')}”
      </blockquote>
      <p class="mt-8 font-label-sm uppercase tracking-[0.35em] text-heritage-gold">{c('home.scripture_ref')}</p>
      <span class="kente-rule w-24 mx-auto mt-8 is-light"></span>
    </div>
  </section>

  <!-- This Week — service times as elevated cards -->
  {
    serviceTimes.length > 0 && (
      <section class="py-24 md:py-36 bg-surface">
        <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop">
          <SectionIntro eyebrow="Join Us" title="This Week" />
          <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
            {serviceTimes.map((s, i) => (
              <div
                class="card-lift bg-surface-container-lowest border border-champagne elev-1 p-8 text-center"
                data-reveal
                style={`--reveal-delay:${i * 100}ms`}
              >
                <Adinkra symbol="adinkrahene" class="w-7 h-7 text-heritage-gold/70 mx-auto mb-5" />
                <h3 class="font-display text-headline-md text-primary mb-2">{s.name}</h3>
                <p class="font-display text-2xl text-heritage-gold mb-2">{s.time}</p>
                {s.note && <p class="font-body text-body-md text-stone-gray">{s.note}</p>}
              </div>
            ))}
          </div>
          <div class="text-center mt-14" data-reveal>
            <a
              href="/visit"
              class="inline-flex items-center gap-3 bg-heritage-gold text-primary hover:bg-secondary hover:text-white font-label-md uppercase tracking-[0.14em] px-10 py-4 transition-colors"
            >
              Plan Your Visit
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- Latest sermon -->
  {feature('sermons') && (
  <section class="bg-primary-container py-24 md:py-32">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="flex justify-between items-end mb-16" data-reveal>
        <div>
          <span class="text-heritage-gold font-label-sm uppercase tracking-[0.3em] mb-4 block">
            {latestSermon?.series ?? 'Current Series'}
          </span>
          <h2 class="font-display text-display-mobile md:text-headline-lg text-white">Latest Sermon</h2>
        </div>
        <a href="/sermons" class="hidden md:inline-flex items-center gap-2 text-heritage-gold font-label-md uppercase tracking-[0.14em] link-underline">
          View Archive
        </a>
      </div>
      <a
        href={latestSermon ? `/sermons/${latestSermon.slug}` : '/sermons'}
        class="relative aspect-video group block overflow-hidden border border-white/10"
        data-reveal
        style="--reveal-delay:120ms"
      >
        <img src={PLACEHOLDER.card} alt="Latest sermon" class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-1000" />
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-20 h-20 md:w-24 md:h-24 rounded-full border border-heritage-gold/50 flex items-center justify-center bg-white/5 backdrop-blur-sm group-hover:scale-110 transition-transform duration-500">
            <svg class="w-10 h-10 text-white translate-x-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 p-8 md:p-12 bg-gradient-to-t from-black/80 to-transparent w-full">
          <h3 class="text-white font-display text-headline-md mb-2">{latestSermon?.title ?? 'Watch our latest message'}</h3>
          <p class="text-white/70 font-body text-body-md">
            {latestSermon?.speaker ?? SITE.name}{latestSermon?.sermon_date ? ` · ${fmtDate(latestSermon.sermon_date)}` : ''}
          </p>
        </div>
      </a>
    </div>
  </section>
  )}

  <!-- Upcoming gatherings -->
  {feature('events') && (
  <section class="py-24 md:py-40 bg-surface-container-low">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop">
      <SectionIntro eyebrow="Mark Your Calendar" title="Upcoming Gatherings" class="mb-20" />
      {
        events.length === 0 ? (
          <p class="text-center text-stone-gray font-body">New gatherings are being planned — check back soon.</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
            {events.map((e, i) => (
              <a
                href={`/events/${e.slug}`}
                class="card-lift group border border-champagne bg-surface-container-lowest elev-1 block overflow-hidden"
                data-reveal
                style={`--reveal-delay:${i * 110}ms`}
              >
                <div class="aspect-[4/3] overflow-hidden">
                  <img src={eventImages[i % eventImages.length]} alt={e.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                </div>
                <div class="p-8">
                  <div class="flex justify-between items-start mb-4">
                    <span class="text-heritage-gold font-label-sm font-bold uppercase tracking-widest">{e.category ?? 'Event'}</span>
                    <span class="text-stone-gray font-label-sm uppercase">{fmtDate(e.start_at)}</span>
                  </div>
                  <h3 class="font-display text-headline-md text-primary mb-4 group-hover:text-heritage-gold transition-colors">{e.title}</h3>
                  <p class="text-stone-gray font-body text-body-md mb-8 line-clamp-3">{e.description}</p>
                  <span class="text-primary font-label-md uppercase tracking-[0.14em] border-b border-primary/20 group-hover:border-heritage-gold transition-colors inline-block">
                    Learn More
                  </span>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
  )}

  <!-- Giving -->
  {feature('giving') && (
  <section class="relative py-32 overflow-hidden bg-primary">
    <img src={cimg('home.giving_image')} alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 mix-blend-luminosity" />
    <div class="relative z-10 max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop text-center">
      <div class="max-w-2xl mx-auto" data-reveal>
        <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-5 block">{c('home.giving_eyebrow')}</span>
        <h2 class="font-display text-display-mobile md:text-headline-lg text-white mb-6">{c('home.giving_heading')}</h2>
        <p class="text-white/80 font-body text-body-lg mb-12 whitespace-pre-line">{c('home.giving_body')}</p>
        <div class="flex flex-col md:flex-row gap-5 justify-center">
          <a href="/giving" class="bg-heritage-gold text-primary hover:bg-secondary hover:text-white font-label-md uppercase tracking-[0.14em] px-12 py-5 transition-colors duration-300">{c('home.giving_cta1_label')}</a>
          <a href="/visit" class="btn-fill border border-white/30 text-white font-label-md uppercase tracking-[0.14em] px-12 py-5">{c('home.giving_cta2_label')}</a>
        </div>
      </div>
    </div>
  </section>
  )}
</PublicLayout>
