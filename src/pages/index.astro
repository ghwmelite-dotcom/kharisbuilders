---
import PublicLayout from '../layouts/PublicLayout.astro';
import { env } from '../lib/runtime';
import { listPublishedSermons } from '../lib/db/sermons';
import { listUpcomingEvents } from '../lib/db/events';

let latestSermon: Awaited<ReturnType<typeof listPublishedSermons>>[number] | null = null;
let events: Awaited<ReturnType<typeof listUpcomingEvents>> = [];
try {
  const [s, e] = await Promise.all([listPublishedSermons(env.DB, 1), listUpcomingEvents(env.DB, 3)]);
  latestSermon = s[0] ?? null;
  events = e;
} catch {
  /* fall back to static content */
}
const eventImages = ['/images/home-4.jpg', '/images/home-5.jpg', '/images/home-6.jpg'];
const fmtDate = (s: string) => s?.slice(0, 10) ?? '';
---
<PublicLayout title="Kharisbuilders | Building Lives, Shaping Destinies">
  <!-- Cinematic hero -->
  <section class="relative min-h-dvh flex items-center justify-center overflow-hidden bg-primary">
    <img src="/images/home-1.jpg" alt="The Kharisbuilders sanctuary" class="kenburns absolute inset-0 w-full h-full object-cover opacity-35" />
    <div class="hero-glows absolute inset-0 pointer-events-none">
      <span class="glow glow-orange"></span>
      <span class="glow glow-blue"></span>
      <span class="glow glow-purple"></span>
      <span class="glow glow-red"></span>
    </div>
    <div class="absolute inset-0" style="background: radial-gradient(130% 90% at 50% 28%, transparent 28%, rgba(4,22,44,0.78) 100%);"></div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto pt-20">
      <img src="/images/kharis-logo.png" alt="" class="hero-swirl hero-fade w-20 h-20 md:w-24 md:h-24 mx-auto mb-7" style="--line-delay:0ms" />
      <span class="hero-line font-label-sm uppercase tracking-[0.45em] text-heritage-gold mb-6 block" style="--line-delay:140ms">Welcome Home</span>
      <h1 class="font-display text-display-mobile md:text-display-lg text-white mb-10" style="text-shadow:0 2px 24px rgba(0,0,0,0.5);">
        <span class="hero-line block" style="--line-delay:240ms">Building Lives,</span>
        <span class="hero-line block text-gold-gradient" style="--line-delay:360ms">Shaping Destinies.</span>
      </h1>

      <!-- Live next-gathering countdown -->
      <div class="hero-fade inline-flex flex-wrap justify-center items-center gap-x-5 gap-y-2 glass-card rounded-full px-7 py-3.5 mb-9" style="--line-delay:560ms">
        <span class="font-label-sm uppercase tracking-[0.25em] text-heritage-gold">Next Gathering</span>
        <span class="w-px h-6 bg-white/20 hidden sm:block"></span>
        <span id="hero-countdown" class="font-display text-white text-xl tabular-nums tracking-wide">—</span>
        <span class="w-px h-6 bg-white/20 hidden sm:block"></span>
        <span id="hero-next" class="font-body text-body-md text-white/70 hidden sm:block">Sunday · 9:00 AM</span>
      </div>

      <div class="hero-fade flex flex-col sm:flex-row gap-4 justify-center items-center" style="--line-delay:680ms">
        <a href="/visit" class="bg-heritage-gold text-primary hover:bg-secondary hover:text-white font-label-md uppercase tracking-[0.14em] px-10 py-5 transition-colors duration-300">Join Us This Sunday</a>
        <a href="/sermons" class="btn-fill border border-white/40 text-white font-label-md uppercase tracking-[0.14em] px-10 py-5">Watch Online</a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 text-white/45">
      <span class="font-label-sm uppercase tracking-[0.3em]">Scroll</span>
      <span class="w-px h-10 bg-gradient-to-b from-heritage-gold to-transparent"></span>
    </div>
  </section>
  <script>
    (function () {
      const out = document.getElementById('hero-countdown');
      const nextEl = document.getElementById('hero-next');
      if (!out) return;
      const sched = [
        [0, 9, 0, 'Sunday · 9:00 AM'],
        [0, 17, 30, 'Sunday · 5:30 PM'],
        [3, 19, 0, 'Wednesday · 7:00 PM'],
      ];
      function nextOccurrence(day, h, m) {
        const now = new Date();
        const d = new Date(now);
        d.setHours(h, m, 0, 0);
        let add = (day - d.getDay() + 7) % 7;
        if (add === 0 && d <= now) add = 7;
        d.setDate(d.getDate() + add);
        return d;
      }
      function tick() {
        const now = new Date();
        let best = null;
        let bestLabel = '';
        for (const [day, h, m, label] of sched) {
          const t = nextOccurrence(day, h, m);
          if (!best || t < best) {
            best = t;
            bestLabel = label;
          }
        }
        let s = Math.max(0, Math.floor((best.getTime() - now.getTime()) / 1000));
        const dd = Math.floor(s / 86400);
        s %= 86400;
        const hh = Math.floor(s / 3600);
        s %= 3600;
        const mm = Math.floor(s / 60);
        const ss = s % 60;
        const pad = (n) => String(n).padStart(2, '0');
        out.textContent = `${dd}d ${pad(hh)}h ${pad(mm)}m ${pad(ss)}s`;
        if (nextEl) nextEl.textContent = bestLabel;
      }
      tick();
      setInterval(tick, 1000);
    })();
  </script>

  <!-- Pastor's welcome -->
  <section class="py-24 md:py-40 bg-surface">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-gutter items-center">
      <div class="md:col-span-5 relative" data-reveal>
        <div class="aspect-[3/4] overflow-hidden border border-heritage-gold/20 shadow-ambient">
          <img src="/images/home-2.jpg" alt="Our Lead Pastor" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="absolute -bottom-8 -right-8 w-48 h-48 bg-heritage-gold/10 -z-10 hidden md:block"></div>
      </div>
      <div class="md:col-span-7 md:pl-16 mt-16 md:mt-0" data-reveal style="--reveal-delay:120ms">
        <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-5 block">A Word of Welcome</span>
        <h2 class="font-display text-display-mobile md:text-headline-lg text-primary mb-8">A Message from Our Pastor</h2>
        <p class="font-body text-body-lg text-stone-gray mb-6 leading-relaxed">
          Welcome to Kharisbuilders. We believe that every individual has a divine blueprint — a destiny waiting to be
          realized. Our mission is to provide the spiritual foundation and community support needed to build that life.
        </p>
        <p class="font-body text-body-lg text-stone-gray mb-10 leading-relaxed">
          Whether you are exploring faith for the first time or seeking a deeper connection with your Creator, there is
          a place for you in our sanctuary. We are more than a congregation; we are architects of hope.
        </p>
        <div class="flex items-center gap-4">
          <div class="h-px w-12 bg-heritage-gold"></div>
          <span class="font-display text-headline-md text-primary italic">Lead Pastor David Anderson</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest sermon -->
  <section class="bg-primary-container py-24 md:py-32">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="flex justify-between items-end mb-16" data-reveal>
        <div>
          <span class="text-heritage-gold font-label-sm uppercase tracking-[0.3em] mb-4 block">
            {latestSermon?.series ?? 'Current Series'}
          </span>
          <h2 class="font-display text-display-mobile md:text-headline-lg text-white">Latest Sermon</h2>
        </div>
        <a href="/sermons" class="hidden md:inline-flex items-center gap-2 text-heritage-gold font-label-md uppercase tracking-[0.14em] link-underline">
          View Archive
        </a>
      </div>
      <a
        href={latestSermon ? `/sermons/${latestSermon.slug}` : '/sermons'}
        class="relative aspect-video group block overflow-hidden border border-white/10"
        data-reveal
        style="--reveal-delay:120ms"
      >
        <img src="/images/home-3.jpg" alt="Latest sermon" class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-1000" />
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-20 h-20 md:w-24 md:h-24 rounded-full border border-heritage-gold/50 flex items-center justify-center bg-white/5 backdrop-blur-sm group-hover:scale-110 transition-transform duration-500">
            <svg class="w-10 h-10 text-white translate-x-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 p-8 md:p-12 bg-gradient-to-t from-black/80 to-transparent w-full">
          <h3 class="text-white font-display text-headline-md mb-2">{latestSermon?.title ?? 'Watch our latest message'}</h3>
          <p class="text-white/70 font-body text-body-md">
            {latestSermon?.speaker ?? 'Kharisbuilders'}{latestSermon?.sermon_date ? ` · ${fmtDate(latestSermon.sermon_date)}` : ''}
          </p>
        </div>
      </a>
    </div>
  </section>

  <!-- Upcoming gatherings -->
  <section class="py-24 md:py-40 bg-surface">
    <div class="max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="text-center mb-20" data-reveal>
        <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-4 block">Mark Your Calendar</span>
        <h2 class="font-display text-display-mobile md:text-headline-lg text-primary mb-5">Upcoming Gatherings</h2>
        <div class="h-px w-24 hairline-gold mx-auto"></div>
      </div>
      {
        events.length === 0 ? (
          <p class="text-center text-stone-gray font-body">New gatherings are being planned — check back soon.</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {events.map((e, i) => (
              <a
                href={`/events/${e.slug}`}
                class="group border border-champagne-light/40 hover:border-heritage-gold/40 transition-all duration-500 bg-surface-container-lowest block hover:-translate-y-1.5 hover:shadow-ambient"
                data-reveal
                style={`--reveal-delay:${i * 110}ms`}
              >
                <div class="aspect-[4/3] overflow-hidden">
                  <img src={eventImages[i % eventImages.length]} alt={e.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                </div>
                <div class="p-8">
                  <div class="flex justify-between items-start mb-4">
                    <span class="text-heritage-gold font-label-sm font-bold uppercase tracking-widest">{e.category ?? 'Event'}</span>
                    <span class="text-stone-gray font-label-sm uppercase">{fmtDate(e.start_at)}</span>
                  </div>
                  <h3 class="font-display text-headline-md text-primary mb-4 group-hover:text-heritage-gold transition-colors">{e.title}</h3>
                  <p class="text-stone-gray font-body text-body-md mb-8 line-clamp-3">{e.description}</p>
                  <span class="text-primary font-label-md uppercase tracking-[0.14em] border-b border-primary/20 group-hover:border-heritage-gold transition-colors inline-block">
                    Learn More
                  </span>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Giving -->
  <section class="relative py-32 overflow-hidden bg-primary">
    <img src="/images/home-7.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 mix-blend-luminosity" />
    <div class="relative z-10 max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop text-center">
      <div class="max-w-2xl mx-auto" data-reveal>
        <span class="font-label-sm uppercase tracking-[0.3em] text-heritage-gold mb-5 block">Generosity</span>
        <h2 class="font-display text-display-mobile md:text-headline-lg text-white mb-6">Invest in Destinies</h2>
        <p class="text-white/80 font-body text-body-lg mb-12">
          Your generosity fuels our mission to build lives and shape destinies. Together, we can make an eternal impact
          on our community and beyond.
        </p>
        <div class="flex flex-col md:flex-row gap-5 justify-center">
          <a href="/give" class="bg-heritage-gold text-primary hover:bg-secondary hover:text-white font-label-md uppercase tracking-[0.14em] px-12 py-5 transition-colors duration-300">Give Online</a>
          <a href="/visit" class="btn-fill border border-white/30 text-white font-label-md uppercase tracking-[0.14em] px-12 py-5">Plan a Visit</a>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
