---
import PublicLayout from '../layouts/PublicLayout.astro';
import PageHero from '../components/PageHero.astro';
import { env } from '../lib/runtime';
import { mediaUrl } from '../lib/media';
import { PLACEHOLDER } from '../lib/images';
import { SITE } from '../lib/seo';
import { listPublishedMinistries, type Ministry } from '../lib/db/ministries';
import { getAllContent } from '../lib/db/content';
import { makeImage } from '../lib/content/content';
import { feature } from '../config/church';

if (!feature('ministries')) return Astro.redirect('/');

const cimg = makeImage(await getAllContent(env.DB).catch(() => ({})));

let ministries: Ministry[] = [];
try {
  ministries = await listPublishedMinistries(env.DB);
} catch {
  ministries = [];
}

const bento = [
  { span: 'md:col-span-8', img: PLACEHOLDER.card, dark: false, big: true },
  { span: 'md:col-span-4', img: PLACEHOLDER.card, dark: false, big: false },
  { span: 'md:col-span-4', img: PLACEHOLDER.card, dark: false, big: false },
  { span: 'md:col-span-8', img: PLACEHOLDER.card, dark: true, big: true },
  { span: 'md:col-span-12', img: PLACEHOLDER.card, dark: false, big: true },
];
const cfg = (i: number) => bento[i] ?? { span: 'md:col-span-4', img: PLACEHOLDER.card, dark: false, big: false };
---
<PublicLayout
  title={`Ministries | ${SITE.name}`}
  description={`Find your place and get involved at ${SITE.name}.`}
  image={cimg('pages.ministries_hero')}
>
  <!-- Hero -->
  <PageHero image={cimg('pages.ministries_hero')}>
    <span class="font-label-sm text-heritage-gold uppercase tracking-[0.3em] mb-4 block hero-shadow">Our Community</span>
    <h1 class="font-display text-display-mobile md:text-display-lg text-white mb-6 hero-shadow">Ministries</h1>
    <p class="font-body text-body-lg text-white/85 max-w-2xl mx-auto hero-shadow">
      Finding your place in the body of Christ. We believe every individual has a unique calling and a part to play in
      building the Kingdom.
    </p>
  </PageHero>

  {
    feature('community') && (
      <div class="bg-primary-container text-on-primary py-10 px-margin-mobile md:px-margin-desktop">
        <div class="max-w-[var(--container-max)] mx-auto flex flex-col sm:flex-row items-center justify-between gap-5 text-center sm:text-left">
          <p class="font-display text-headline-md text-white">Looking for a smaller circle? Find a group.</p>
          <a href="/groups" class="flex-none bg-heritage-gold text-primary font-label-md uppercase tracking-widest px-8 py-3 hover:bg-secondary transition-colors">Find a group</a>
        </div>
      </div>
    )
  }

  <!-- Bento grid -->
  <main class="py-24 px-margin-mobile md:px-margin-desktop max-w-[var(--container-max)] mx-auto">
    {
      ministries.length === 0 ? (
        <p class="text-center text-stone-gray font-body">Our ministries are being prepared — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8" data-reveal>
          {ministries.map((m, i) => {
            const c = cfg(i);
            const img = mediaUrl(m.image_key) ?? c.img;
            return c.dark ? (
              <div class={`card-lift elev-2 group relative overflow-hidden bg-primary text-white min-h-[360px] ${c.span}`}>
                <img src={img} alt={m.name} class="absolute inset-0 w-full h-full object-cover opacity-40 grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105" />
                <div class="relative z-10 p-10 md:p-12 flex flex-col justify-end h-full min-h-[360px]">
                  <h2 class="font-display text-headline-lg text-white mb-4">{m.name}</h2>
                  <p class="font-body text-body-lg text-white/80 mb-2 max-w-lg">{m.description}</p>
                  {m.meeting_time && <p class="font-label-sm uppercase tracking-widest text-heritage-gold">{m.meeting_time}</p>}
                </div>
              </div>
            ) : (
              <div class={`card-lift elev-1 group relative overflow-hidden bg-surface-container border border-champagne ${c.span}`}>
                <div class={`overflow-hidden ${c.big ? 'aspect-[16/9]' : 'aspect-square'}`}>
                  <img src={img} alt={m.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                </div>
                <div class="p-8 md:p-10">
                  <h2 class={`font-display ${c.big ? 'text-headline-lg' : 'text-headline-md'} text-primary mb-4`}>{m.name}</h2>
                  <p class="font-body text-body-md text-stone-gray mb-4 max-w-xl">{m.description}</p>
                  {m.meeting_time && <p class="font-label-sm uppercase tracking-widest text-heritage-gold">{m.meeting_time}</p>}
                  {m.leader && (
                    <p class="font-body text-body-md text-stone-gray mt-2">
                      Led by <span class="text-primary">{m.leader}</span>
                    </p>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      )
    }
  </main>

  <!-- CTA -->
  <section class="bg-surface-container-high py-24 text-center">
    <div class="max-w-3xl mx-auto px-4" data-reveal>
      <span class="kente-rule w-16 mx-auto mb-8 block"></span>
      <h2 class="font-display text-display-mobile md:text-headline-lg text-primary mb-6 pullquote">Can't find what you're looking for?</h2>
      <p class="font-body text-body-lg text-stone-gray mb-10">
        Our team is here to help you navigate your journey and find the ministry that best fits your gifts and season of
        life.
      </p>
      <a href="/visit" class="inline-flex items-center gap-3 font-label-md text-primary uppercase tracking-[0.2em] border-b border-heritage-gold pb-1">
        Contact Our Team
      </a>
    </div>
  </section>
</PublicLayout>
