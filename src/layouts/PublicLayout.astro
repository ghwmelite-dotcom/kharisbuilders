---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { resolveTheme } from '../lib/theme';
import { env } from '../lib/runtime';
import { getAllSettings, type SettingsMap } from '../lib/db/settings';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Kharisbuilders — Building Lives, Shaping Destinies.' } = Astro.props;
const theme = resolveTheme(Astro.cookies.get('theme')?.value);

let settings: SettingsMap = {};
try {
  settings = await getAllSettings(env.DB);
} catch {
  settings = {};
}
---
<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preload" href="/fonts/playfair-display.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/manrope.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <Nav />
    <main><slot /></main>
    <Footer settings={settings} />
  </body>
</html>
