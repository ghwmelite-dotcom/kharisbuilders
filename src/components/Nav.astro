---
import Icon from './Icon.astro';
import { CHURCH, feature, type ChurchFeatures } from '../config/church';

// `highlight` renders the item as a distinct gold-tagged pill (used for Prayer Wall).
type Leaf = { label: string; href: string; gate?: keyof ChurchFeatures; highlight?: boolean };
type Group = { label: string; children: Leaf[] };
type Entry = Leaf | Group;
const isGroup = (e: Entry): e is Group => 'children' in e;

// Top-level nav is intentionally small. Secondary destinations live in grouped
// dropdowns; Prayer Wall is pulled out and highlighted; "Visit" is the "New Here?" CTA.
const allEntries: Entry[] = [
  { label: 'Home', href: '/' },
  {
    label: 'About',
    children: [
      { label: 'About Us', href: '/about' },
      { label: 'Ministries', href: '/ministries', gate: 'ministries' },
    ],
  },
  {
    label: 'Media',
    children: [
      { label: 'Sermons', href: '/sermons', gate: 'sermons' },
      { label: 'Watch Live', href: '/live', gate: 'live' },
      { label: 'Blog', href: '/blog', gate: 'blog' },
    ],
  },
  { label: 'Events', href: '/events', gate: 'events' },
  { label: 'Prayer Wall', href: '/prayer', gate: 'community', highlight: true },
  { label: 'Give', href: '/giving', gate: 'giving' },
];

const showLeaf = (l: Leaf) => !l.gate || feature(l.gate);
// Filter gated leaves; drop any group left with no children.
const entries: Entry[] = allEntries
  .map((e) => (isGroup(e) ? { ...e, children: e.children.filter(showLeaf) } : e))
  .filter((e) => (isGroup(e) ? (e as Group).children.length > 0 : showLeaf(e as Leaf)));

const path = Astro.url.pathname;
const leafActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const entryActive = (e: Entry) => (isGroup(e) ? e.children.some((c) => leafActive(c.href)) : leafActive(e.href));
---
<header id="site-header" data-nav class="fixed top-0 inset-x-0 z-50">
  <div class="nav-shell mx-auto max-w-[var(--container-max)] px-3 md:px-6">
    <nav class="nav-bar relative flex h-[4.75rem] items-center justify-between px-5 md:px-7">
      <a href="/" class="nav-brand flex items-center gap-3 group" aria-label={`${CHURCH.name} — home`}>
        <img src={CHURCH.logo} alt="" width="40" height="40" class="nav-mark w-9 h-9 md:w-10 md:h-10" />
        <span class="nav-logo font-display text-2xl tracking-tight">{CHURCH.name}</span>
      </a>

      <div class="hidden md:flex items-center">
        <div class="nav-links flex items-center gap-1">
          {
            entries.map((e) =>
              isGroup(e) ? (
                <div class="nav-group relative">
                  <button
                    type="button"
                    class={`nav-link nav-trigger inline-flex items-center gap-1.5 text-label-sm uppercase tracking-[0.12em] ${entryActive(e) ? 'is-active' : ''}`}
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {e.label}
                    <svg class="nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M6 9l6 6 6-6" />
                    </svg>
                  </button>
                  <div class="nav-menu" role="menu">
                    {e.children.map((c) => (
                      <a
                        href={c.href}
                        role="menuitem"
                        class={`nav-menu-link text-label-sm uppercase tracking-[0.12em] ${leafActive(c.href) ? 'is-active' : ''}`}
                        aria-current={leafActive(c.href) ? 'page' : undefined}
                      >
                        {c.label}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (e as Leaf).highlight ? (
                <a
                  href={e.href}
                  class={`nav-link nav-highlight inline-flex items-center gap-1.5 text-label-sm uppercase tracking-[0.12em] ${entryActive(e) ? 'is-active' : ''}`}
                  aria-current={entryActive(e) ? 'page' : undefined}
                >
                  <svg class="nav-hl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" />
                  </svg>
                  {e.label}
                </a>
              ) : (
                <a
                  href={e.href}
                  class={`nav-link text-label-sm uppercase tracking-[0.12em] ${entryActive(e) ? 'is-active' : ''}`}
                  aria-current={entryActive(e) ? 'page' : undefined}
                >
                  {e.label}
                </a>
              ),
            )
          }
        </div>
        <a href="/visit" class="nav-cta ml-6 text-label-sm uppercase tracking-[0.12em]">New Here?</a>
      </div>

      <button
        id="mobile-menu-toggle"
        class="nav-link md:hidden p-2 -mr-1"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" />
      </button>
    </nav>
  </div>

  <div id="mobile-menu" class="md:hidden hidden mx-3 mt-2 rounded-2xl border border-accent/20 bg-primary/92 backdrop-blur-xl px-5 py-5 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.6)]">
    <div class="flex flex-col gap-1">
      {
        entries.map((e) =>
          isGroup(e) ? (
            <div class="nav-mobile-group">
              <span class="nav-mobile-label">{e.label}</span>
              {e.children.map((c) => (
                <a
                  href={c.href}
                  class={`nav-mobile-link ${leafActive(c.href) ? 'is-active' : ''}`}
                  aria-current={leafActive(c.href) ? 'page' : undefined}
                >
                  {c.label}
                </a>
              ))}
            </div>
          ) : (
            <a
              href={e.href}
              class={`nav-mobile-link ${(e as Leaf).highlight ? 'nav-mobile-highlight' : ''} ${entryActive(e) ? 'is-active' : ''}`}
              aria-current={entryActive(e) ? 'page' : undefined}
            >
              {(e as Leaf).highlight && (
                <svg class="nav-hl-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" />
                </svg>
              )}
              {e.label}
            </a>
          ),
        )
      }
      <a href="/visit" class="nav-cta mt-4 text-center text-label-sm uppercase tracking-[0.12em]">New Here?</a>
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('nav-scrolled', window.scrollY > 40);
  onScroll();
  document.addEventListener('scroll', onScroll, { passive: true });

  // Dropdown menus: CSS handles hover + keyboard focus-within; this adds
  // click/tap toggling (touch devices have no hover) and outside-click / Escape close.
  const groups = Array.from(document.querySelectorAll('[data-nav] .nav-group')) as HTMLElement[];
  const closeAll = (except?: HTMLElement) => {
    for (const g of groups) {
      if (g === except) continue;
      g.classList.remove('is-open');
      g.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
    }
  };
  for (const g of groups) {
    const trigger = g.querySelector('.nav-trigger') as HTMLButtonElement | null;
    trigger?.addEventListener('click', (e) => {
      e.preventDefault();
      const open = g.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', String(open));
      closeAll(g);
    });
  }
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement)?.closest('.nav-group')) closeAll();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });

  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
