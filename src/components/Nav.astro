---
import Icon from './Icon.astro';
const links = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Ministries', href: '/ministries' },
  { label: 'Sermons', href: '/sermons' },
  { label: 'Events', href: '/events' },
  { label: 'Visit', href: '/visit' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header id="site-header" data-nav class="fixed top-0 inset-x-0 z-50">
  <nav class="mx-auto flex h-20 max-w-[var(--container-max)] items-center justify-between px-6 md:px-margin-desktop">
    <a href="/" class="nav-logo font-display text-2xl tracking-tight">Kharisbuilders</a>
    <div class="hidden md:flex items-center gap-9">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`nav-link link-underline text-label-sm uppercase tracking-[0.12em] ${isActive(l.href) ? 'is-active' : ''}`}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/visit" class="nav-cta text-label-sm uppercase tracking-[0.12em] px-6 py-3">New Here?</a>
    </div>
    <button
      id="mobile-menu-toggle"
      class="nav-link md:hidden p-2 -mr-2"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Icon name="menu" />
    </button>
  </nav>
  <div id="mobile-menu" class="md:hidden hidden bg-surface/95 backdrop-blur-xl border-t border-accent/15 px-6 py-4">
    <div class="flex flex-col gap-1">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="py-3 text-label-sm uppercase tracking-[0.12em] text-on-surface-variant hover:text-primary transition-colors"
          >
            {l.label}
          </a>
        ))
      }
      <a href="/visit" class="mt-2 bg-primary text-on-primary text-center px-6 py-3 text-label-sm uppercase tracking-[0.12em]">
        New Here?
      </a>
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('nav-scrolled', window.scrollY > 40);
  onScroll();
  document.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
