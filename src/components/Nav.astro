---
import Icon from './Icon.astro';
import { CHURCH, feature, type ChurchFeatures } from '../config/church';
const allLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Ministries', href: '/ministries' },
  { label: 'Sermons', href: '/sermons' },
  { label: 'Watch', href: '/live' },
  { label: 'Events', href: '/events' },
  { label: 'Give', href: '/giving' },
  { label: 'Prayer', href: '/prayer' },
  { label: 'Visit', href: '/visit' },
];
// Links whose page is feature-gated; the rest (Home/About/Visit) are always shown.
const featureOf: Record<string, keyof ChurchFeatures | undefined> = {
  '/ministries': 'ministries',
  '/sermons': 'sermons',
  '/live': 'live',
  '/events': 'events',
  '/giving': 'giving',
  '/prayer': 'community',
};
const links = allLinks.filter((l) => {
  const f = featureOf[l.href];
  return !f || feature(f);
});
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header id="site-header" data-nav class="fixed top-0 inset-x-0 z-50">
  <div class="nav-shell mx-auto max-w-[var(--container-max)] px-3 md:px-6">
    <nav class="nav-bar relative flex h-[4.75rem] items-center justify-between px-5 md:px-7">
      <a href="/" class="nav-brand flex items-center gap-3 group" aria-label={`${CHURCH.name} — home`}>
        <img
          src={CHURCH.logo}
          alt=""
          width="40"
          height="40"
          class="nav-mark w-9 h-9 md:w-10 md:h-10"
        />
        <span class="nav-logo font-display text-2xl tracking-tight">{CHURCH.name}</span>
      </a>

      <div class="hidden md:flex items-center">
        <div class="nav-links relative flex items-center gap-1">
          <span class="nav-indicator" aria-hidden="true"></span>
          {
            links.map((l) => (
              <a
                href={l.href}
                class={`nav-link text-label-sm uppercase tracking-[0.14em] ${isActive(l.href) ? 'is-active' : ''}`}
                aria-current={isActive(l.href) ? 'page' : undefined}
              >
                {l.label}
              </a>
            ))
          }
        </div>
        <a href="/visit" class="nav-cta ml-5 text-label-sm uppercase tracking-[0.14em]">New Here?</a>
      </div>

      <button
        id="mobile-menu-toggle"
        class="nav-link md:hidden p-2 -mr-1"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" />
      </button>
    </nav>
  </div>

  <div id="mobile-menu" class="md:hidden hidden mx-3 mt-2 rounded-2xl border border-accent/20 bg-primary/92 backdrop-blur-xl px-5 py-4 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.6)]">
    <div class="flex flex-col gap-1">
      {
        links.map((l) => (
          <a
            href={l.href}
            class={`nav-mobile-link py-3 px-2 text-label-sm uppercase tracking-[0.14em] ${isActive(l.href) ? 'is-active' : ''}`}
            aria-current={isActive(l.href) ? 'page' : undefined}
          >
            {l.label}
          </a>
        ))
      }
      <a href="/visit" class="nav-cta mt-3 text-center text-label-sm uppercase tracking-[0.14em]">New Here?</a>
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('nav-scrolled', window.scrollY > 40);
  onScroll();
  document.addEventListener('scroll', onScroll, { passive: true });

  // Magnetic gold pill that slides under the hovered link.
  const linksWrap = header?.querySelector('.nav-links');
  const indicator = header?.querySelector('.nav-indicator') as HTMLElement | null;
  const linkEls = linksWrap ? Array.from(linksWrap.querySelectorAll('.nav-link')) as HTMLElement[] : [];
  const moveTo = (el: HTMLElement) => {
    if (!indicator) return;
    indicator.style.width = el.offsetWidth + 'px';
    indicator.style.transform = `translate(${el.offsetLeft}px, -50%)`;
    indicator.style.opacity = '1';
  };
  linkEls.forEach((a) => a.addEventListener('mouseenter', () => moveTo(a)));
  linksWrap?.addEventListener('mouseleave', () => {
    if (indicator) indicator.style.opacity = '0';
  });

  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
