---
/**
 * Subtle Adinkra (Ghanaian) symbol motif.
 * - adinkrahene: three concentric circles — greatness, charisma, leadership.
 *   The "chief" of Adinkra symbols; used site-wide as our signature flourish.
 * - nyame-dua: the altar/tree of God — a symbol of God's presence and protection.
 * Decorative by default (aria-hidden); pass a `title` to expose its meaning to AT.
 */
import { CHURCH } from '../config/church';
interface Props {
  symbol?: 'adinkrahene' | 'nyame-dua';
  class?: string;
  title?: string;
}
const { symbol = 'adinkrahene', class: cls = 'w-5 h-5', title } = Astro.props;
const a11y = title ? { role: 'img', 'aria-label': title } : { 'aria-hidden': 'true' };
---
{
  CHURCH.motifs && symbol === 'adinkrahene' && (
    <svg viewBox="0 0 64 64" class={cls} fill="none" stroke="currentColor" {...a11y}>
      <circle cx="32" cy="32" r="28" stroke-width="2.4" />
      <circle cx="32" cy="32" r="18" stroke-width="2.4" />
      <circle cx="32" cy="32" r="8" stroke-width="2.4" />
      <circle cx="32" cy="32" r="2" fill="currentColor" stroke="none" />
    </svg>
  )
}
{
  CHURCH.motifs && symbol === 'nyame-dua' && (
    <svg viewBox="0 0 64 64" class={cls} fill="none" stroke="currentColor" {...a11y}>
      <path d="M32 6 V58 M6 32 H58" stroke-width="2.4" stroke-linecap="round" />
      <circle cx="32" cy="32" r="6.5" stroke-width="2.4" />
      <circle cx="32" cy="11" r="4" stroke-width="2.2" />
      <circle cx="32" cy="53" r="4" stroke-width="2.2" />
      <circle cx="11" cy="32" r="4" stroke-width="2.2" />
      <circle cx="53" cy="32" r="4" stroke-width="2.2" />
    </svg>
  )
}
