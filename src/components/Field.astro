---
interface Props {
  label: string;
  name: string;
  type?: string;
  required?: boolean;
  options?: string[];
  value?: string;
  checked?: boolean;
  textarea?: boolean;
  min?: number;
  max?: number;
}
const {
  label,
  name,
  type = 'text',
  required = false,
  options,
  value = '',
  checked = false,
  textarea = false,
  min,
  max,
} = Astro.props;
const id = `f-${name}`;
const base =
  'bg-transparent border-0 border-b border-on-surface-variant/30 focus:border-primary focus:ring-0 py-2 min-h-[44px]';
---
{
  type === 'checkbox' ? (
    <label class="flex items-center gap-3 min-h-[44px]">
      <input id={id} name={name} type="checkbox" checked={checked} class="h-4 w-4" />
      <span class="text-xs uppercase tracking-wider text-on-surface-variant">{label}</span>
    </label>
  ) : (
    <div class="flex flex-col gap-1">
      <label for={id} class="text-xs uppercase tracking-wider text-on-surface-variant">
        {label}
      </label>
      {textarea ? (
        <textarea id={id} name={name} required={required} rows="4" class={base}>
          {value}
        </textarea>
      ) : options ? (
        <select id={id} name={name} required={required} class={base}>
          {options.map((o) => (
            <option value={o} selected={o === value}>
              {o}
            </option>
          ))}
        </select>
      ) : (
        <input id={id} name={name} type={type} required={required} value={value} min={min} max={max} class={base} />
      )}
    </div>
  )
}
