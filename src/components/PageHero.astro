---
interface Props {
  image: string;
  height?: string;
  align?: 'center' | 'bottom';
}
const { image, height = 'h-[460px] md:h-[600px]', align = 'center' } = Astro.props;
const alignWrap = align === 'bottom' ? 'items-end' : 'items-center justify-center';
const contentClass =
  align === 'bottom'
    ? 'w-full max-w-[var(--container-max)] mx-auto px-margin-mobile md:px-margin-desktop pb-14'
    : 'text-center px-6 max-w-4xl mx-auto';
---
<header class={`relative ${height} flex ${alignWrap} overflow-hidden bg-primary`}>
  <img src={image} alt="" class="kenburns absolute inset-0 w-full h-full object-cover opacity-[0.72]" />
  <!-- theme-toned legibility gradient: lets the photo show, darkens top + bottom for the title -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, color-mix(in srgb, var(--kb-primary-container) 50%, transparent) 0%, color-mix(in srgb, var(--kb-primary-container) 12%, transparent) 46%, color-mix(in srgb, var(--kb-primary-container) 80%, transparent) 100%);"
  >
  </div>
  <!-- brand-color glows -->
  <div class="hero-glows absolute inset-0 pointer-events-none opacity-80">
    <span class="glow glow-orange"></span>
    <span class="glow glow-blue"></span>
    <span class="glow glow-purple"></span>
  </div>
  <!-- focused scrim behind text -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(55% 45% at 50% 50%, color-mix(in srgb, var(--kb-primary-container) 44%, transparent), transparent 78%);"
  >
  </div>
  <div class={`relative z-10 ${contentClass}`} data-reveal>
    <slot />
  </div>
</header>
