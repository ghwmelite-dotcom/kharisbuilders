---
import Field from '../Field.astro';
import Button from '../Button.astro';
import type { MinistryFull } from '../../lib/db/ministries';
interface Props {
  ministry?: MinistryFull | null;
}
const { ministry } = Astro.props;
const isEdit = !!ministry;
---
<form method="POST" action="/api/admin/ministries" class="flex flex-col gap-6 max-w-xl">
  <input type="hidden" name="_action" value={isEdit ? 'update' : 'create'} />
  {isEdit && <input type="hidden" name="id" value={String(ministry!.id)} />}
  <Field label="Name" name="name" required value={ministry?.name ?? ''} />
  <Field label="Slug (optional)" name="slug" value={ministry?.slug ?? ''} />
  <Field label="Leader" name="leader" value={ministry?.leader ?? ''} />
  <Field label="Meeting time" name="meeting_time" value={ministry?.meeting_time ?? ''} />
  <Field label="Sort order" name="sort_order" type="number" min={0} value={ministry?.sort_order != null ? String(ministry.sort_order) : '0'} />
  <Field label="Description" name="description" textarea value={ministry?.description ?? ''} />
  <Field label="Published" name="published" type="checkbox" checked={!!ministry?.published} />
  <Button type="submit" variant="primary">{isEdit ? 'Save' : 'Create'}</Button>
</form>
